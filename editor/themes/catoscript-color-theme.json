{
  "name": "catoscript (Kernel Panic palette)",
  "type": "dark",
  "colors": {},
  "tokenColors": [
    {
      "name": "Control flow (jump, purr_at, hiss_at, breed, ...)",
      "scope": ["keyword.control.catoscript"],
      "settings": { "foreground": "#ff79c6", "fontStyle": "bold" }
    },
    {
      "name": "Visual commands (glow, blink, canvas_mode, ...)",
      "scope": ["keyword.visual.catoscript"],
      "settings": { "foreground": "#00f2ff" }
    },
    {
      "name": "System commands (include, coat, sniff_env, ...)",
      "scope": ["keyword.system.catoscript"],
      "settings": { "foreground": "#f1fa8c" }
    },
    {
      "name": "Neural commands (synapse, train, think, ...)",
      "scope": ["keyword.neural.catoscript"],
      "settings": { "foreground": "#bd93f9" }
    },
    {
      "name": "Audio commands (purr, hiss, tempo, chirp, ...)",
      "scope": ["keyword.audio.catoscript"],
      "settings": { "foreground": "#50fa7b" }
    },
    {
      "name": "Action commands (scratch, swat, bat, leap, ...)",
      "scope": ["keyword.action.catoscript"],
      "settings": { "foreground": "#ffb86c" }
    },
    {
      "name": "Meow (distinctive orange)",
      "scope": ["keyword.meow.catoscript"],
      "settings": { "foreground": "#ff6b00", "fontStyle": "bold" }
    },
    {
      "name": "Other keywords (set, sniff, bury, dig, sync)",
      "scope": ["keyword.other.catoscript"],
      "settings": { "foreground": "#ff79c6" }
    },
    {
      "name": "Variables ($name)",
      "scope": ["variable.other.catoscript", "variable.interpolation.catoscript"],
      "settings": { "foreground": "#ff6b6b" }
    },
    {
      "name": "Labels (:START, :LOOP)",
      "scope": ["entity.name.label.catoscript"],
      "settings": { "foreground": "#ff5555", "fontStyle": "bold" }
    },
    {
      "name": "Strings",
      "scope": ["string.quoted.double.catoscript"],
      "settings": { "foreground": "#f1fa8c" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric.catoscript"],
      "settings": { "foreground": "#bd93f9" }
    },
    {
      "name": "Comments",
      "scope": ["comment.line.catoscript"],
      "settings": { "foreground": "#6272a4", "fontStyle": "italic" }
    }
  ]
}